  "keyFeatures": [
    "Thai-first agentic coding loop backed by the Typhoon reasoning provider",
    "Orthogonal Plan and Build work modes with structural read-only enforcement",
    "Three permission profiles: Manual, Assisted, and Full Access",
    "Workspace containment with hard boundaries and non-overridable path enforcement",
    "Encrypted SQLite session storage with DPAPI-backed OS credential store on Windows",
    "Checkpoint-based rollback with three-way conflict analysis",
    "Registry-driven AI for Thai catalog exposing OCR, speech-to-text, address extraction, and NER",
    "Controlled command grammar with deterministic shell-expansion refusal",
    "Sanitized tool output and credential redaction before every reasoning turn",
    "Offline test suite runnable without provider credentials"
  ],
  "publicApiSurface": [
    "thcode (CLI binary)",
    "--version / --help flags",
    "/status (alias: /st)",
    "/permissions (alias: /perm)",
    "/mode — switch Plan/Build work mode",
    "/boundaries (alias: /boundary)",
    "/connections (alias: /conn)",
    "/activity (alias: /act)",
    "/models",
    "/tools",
    "/check",
    "/help (alias: /?, /h)",
    "/rollback (alias: /rb)",
    "/recover (alias: /rc)",
    "/context (alias: /ctx)",
    "/usage",
    "CoreApp TypeScript facade (headless core)",
    "ProviderRegistry — register/select/list provider adapters",
    "COMMAND_GRAMMAR — frozen command specification array",
    "parseCommand() — validate input against grammar",
    "completeCommand() — deterministic tab completion",
    "evaluatePermission() — pure permission policy engine",
    "AgentLoop.runTurn() — single agent turn with approval callback",
    "Catalog services: t-ocr, speech-to-text, extract-address, named-entity-recognition"
  ]
